# ProjectMind API - Environment configuration example
# Copy this file to ".env" and adjust values for your local setup.

# --- Application ---
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# --- PostgreSQL ---
POSTGRES_DB=projectmind
POSTGRES_USER=projectmind
POSTGRES_PASSWORD=projectmind
# JDBC URL used by the application (host "postgres" is the docker-compose service name)
DB_URL=jdbc:postgresql://postgres:5432/projectmind
DB_USERNAME=projectmind
DB_PASSWORD=projectmind

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT ---
# Must be at least 32 characters (256 bits) for HS256. Generate your own secret in real deployments.
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
JWT_ISSUER=projectmind-api
